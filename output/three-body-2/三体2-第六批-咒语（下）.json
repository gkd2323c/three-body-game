  "nodes": {
    "ch5_zhang_001": {
      "chapterTitle": "陨石与钢印",
      "scene": {
        "id": "collector_home",
        "name": "陨石收藏家·四合院",
        "type": "major",
        "description": "正午。一间堆满玻璃柜的老宅，四壁的灯光照着形态各异的石头。空气中有一股灰尘和矿物混合的气味。工作台上放着一把放大镜。",
        "arrival": "你按地址找到了这里。"
      },
      "progress": 1,
      "ambient": "static",
      "segments": [
        {
          "text": "你叫章北海。太空军政治部。你来的目的，只有你自己知道。"
        }
      ],
      "choices": [
        {
          "text": "敲门",
          "next": "ch5_meteor_002"
        }
      ]
    },
    "ch5_meteor_002": {
      "scene": "陨石收藏家·四合院",
      "progress": 3,
      "segments": [
        {
          "speaker": "收藏家",
          "text": "您是军人吧。"
        },
        {
          "speaker": "你",
          "text": "好眼力。"
        },
        {
          "speaker": "收藏家",
          "text": "我大半辈子在总参测绘局服役——找陨石找了几十年。想要什么样的？"
        },
        {
          "speaker": "你",
          "text": "比重大，在冲击下不易破碎，易加工。"
        }
      ],
      "choices": [
        {
          "text": "看样品",
          "next": "ch5_meteor_003"
        }
      ]
    },
    "ch5_meteor_003": {
      "scene": "陨石收藏家·四合院",
      "progress": 5,
      "segments": [
        {
          "text": "他拿出三块铁陨石——苹果大小，暗灰色，表面有细密的交错条纹。"
        },
        {
          "speaker": "你",
          "text": "多少钱？"
        },
        {
          "speaker": "收藏家",
          "text": "国际市场价格每克二十美元。三块，十八万。"
        },
        {
          "text": "你没有还价。"
        }
      ],
      "choices": [
        {
          "text": "付款",
          "next": "ch5_meteor_cb_pay",
          "changes": {
            "set": {
              "zhang_stealth": 45
            }
          }
        },
        {
          "text": "能便宜吗？",
          "next": "ch5_meteor_cb_bargain",
          "changes": {
            "set": {
              "zhang_stealth": 48
            }
          }
        }
      ]
    },
    "ch5_meteor_cb_pay": {
      "scene": "陨石收藏家·四合院",
      "progress": 6,
      "segments": [
        {
          "text": "你付了款，没有多说什么。收藏家看了你一眼，也许觉得你是个爽快人，也许觉得你傻。都一样。"
        }
      ],
      "next": "ch5_workshop_001"
    },
    "ch5_meteor_cb_bargain": {
      "scene": "陨石收藏家·四合院",
      "progress": 6,
      "segments": [
        {
          "text": "「能便宜吗？」你问。他愣了一下，然后摇头。你也没再坚持。这不是讨价还价的时候。"
        }
      ],
      "next": "ch5_workshop_001"
    },
    "ch5_workshop_001": {
      "scene": {
        "id": "workshop",
        "name": "研究所·数控车间",
        "type": "transient",
        "description": "下班后的车间空无一人。机床的金属表面在顶灯下泛着冷光。空气中还有切削液的气味。",
        "arrival": "你带着陨石来到了这里。"
      },
      "progress": 7,
      "segments": [
        {
          "text": "你把三块陨石切成铅笔粗细的圆柱，再切成小段。碎屑收集起来，刀具拆下。没有人看到。"
        }
      ],
      "choices": [
        {
          "text": "开始下一步",
          "next": "ch5_basement_001"
        }
      ]
    },
    "ch5_basement_001": {
      "scene": {
        "id": "basement",
        "name": "地下室",
        "type": "major",
        "description": "隐蔽。入口藏在储物间后面。一盏裸露的白炽灯照着工作台。墙角的铁架子上放着几箱杂物。",
        "arrival": "你锁好门，打开灯。"
      },
      "progress": 9,
      "segments": [
        {
          "text": "三十六发7.62毫米无壳子弹整齐排列在工作台上。你用钳子把弹头取下来——无壳子弹的弹头是直接粘在发射药上的，很容易取下。"
        },
        {
          "text": "你在每发发射药上粘上一段陨石圆柱，用太空舱表皮的胶合剂固定——这种胶能在太空剧烈的冷热交替中不失效。"
        }
      ],
      "choices": [
        {
          "text": "组装完成",
          "next": "ch5_basement_002"
        }
      ]
    },
    "ch5_basement_002": {
      "scene": "地下室",
      "progress": 11,
      "segments": [
        {
          "text": "你拿起装好四发陨石子弹的弹夹，压入手枪。"
        },
        {
          "text": "对着墙角叠好的航天服布料——开枪。"
        }
      ],
      "choices": [
        {
          "text": "检查弹孔",
          "next": "ch5_basement_003"
        }
      ]
    },
    "ch5_basement_003": {
      "scene": "地下室",
      "progress": 13,
      "segments": [
        {
          "text": "弹孔很小。陨石在发射中没有破碎。"
        },
        {
          "text": "你剖开布料，取出嵌在里面的陨石段——已经碎了，成了掌心里一小堆暗灰色的碎石。看不出加工的痕迹。"
        },
        {
          "text": "和预想的一样。"
        }
      ],
      "choices": [
        {
          "text": "收好剩余的子弹",
          "next": "ch5_space_001"
        }
      ]
    },
    "ch5_space_001": {
      "scene": {
        "id": "space_station",
        "name": "同步轨道·黄河站外",
        "type": "major",
        "description": "空旷。寂静。地球在下方缓缓转动，蓝色的半球被大气层的淡金色边缘包裹着。空间站的车轮状结构在前方五公里处，表面的太阳能板反射着刺眼的阳光。没有上下——只有方向和距离。",
        "arrival": "你从一号基地飞出，借助航天服的微型推进器滑行到这里。"
      },
      "progress": 15,
      "ambient": "static",
      "segments": [
        {
          "text": "你悬浮在太空中，距黄河空间站五公里。推进器已经关闭。你像一块石头一样静止在群星之间。"
        },
        {
          "text": "航天服的生命维持系统还能支撑十二个小时。你不需要那么久。"
        }
      ],
      "choices": [
        {
          "text": "等待",
          "next": "ch5_space_002"
        }
      ]
    },
    "ch5_space_002": {
      "scene": "同步轨道·黄河站外",
      "progress": 17,
      "segments": [
        {
          "text": "今天航天系统在黄河站召开高层会议。你知道那三个人会在里面。"
        },
        {
          "text": "日落了。地球的边缘吞没了太阳——光芒从蓝色星球的边缘一圈圈地散去，像最后一轮呼吸。"
        }
      ],
      "choices": [
        {
          "text": "举起瞄准镜",
          "next": "ch5_space_003"
        }
      ]
    },
    "ch5_space_003": {
      "scene": "同步轨道·黄河站外",
      "progress": 19,
      "segments": [
        {
          "text": "密封门打开了。一群白色航天服鱼贯而出——三十人左右。他们在空间站外壁前方减速、悬停、排队。"
        },
        {
          "text": "拍合影。惯例。"
        },
        {
          "text": "你拉大瞄准镜焦距。前排正中——三个目标都在。"
        }
      ],
      "choices": [
        {
          "text": "开火",
          "next": "ch5_space_004"
        }
      ]
    },
    "ch5_space_004": {
      "scene": "同步轨道·黄河站外",
      "progress": 21,
      "effect": "flash",
      "segments": [
        {
          "text": "枪口闪光在太空中像一只萤火虫。没有声音。"
        },
        {
          "text": "你扣动扳机——换弹夹——再扣——再换——再扣。三十发。"
        },
        {
          "text": "十秒钟。陨石弹头以每秒五百米的速度飞向五公里外的目标。没有空气阻力——它们不会减速。"
        }
      ],
      "next": "ch5_space_005"
    },
    "ch5_space_005": {
      "scene": "同步轨道·黄河站外",
      "progress": 23,
      "segments": [
        {
          "text": "你透过瞄准镜观察。白色气体从航天服上喷出。面罩裂了——血飞溅在内壁上，遇到真空立刻冷凝成冰晶。"
        },
        {
          "text": "有人在惊叫。从口型上看——"
        },
        {
          "effect": "noise"
        },
        {
          "speaker": "（无声的嘴型）",
          "text": "陨石雨！"
        }
      ],
      "changes": {
        "addFlag": "zhang_killed_three",
        "unlockAchievement": "three_shots"
      },
      "choices": [
        {
          "text": "返航",
          "next": "ch5_aftermath_001"
        }
      ]
    },
    "ch5_aftermath_001": {
      "scene": {
        "id": "meeting_room",
        "name": "会议室",
        "type": "major",
        "description": "长桌。窗外是木星的橘红色大气在缓缓流动。这里不在地球了——在舰队司令部。空间站的旋转产生微弱的模拟重力。",
        "arrival": "几天后——"
      },
      "progress": 25,
      "segments": [
        {
          "text": "章北海站在亚洲舰队司令官面前。"
        },
        {
          "speaker": "司令官",
          "text": "前辈，你好。"
        },
        {
          "speaker": "章北海",
          "text": "不敢，首长。我现在是一切都要学习的新战士。"
        }
      ],
      "choices": [
        {
          "text": "听司令官讲话",
          "next": "ch5_aftermath_002"
        }
      ]
    },
    "ch5_aftermath_002": {
      "scene": "会议室",
      "progress": 27,
      "segments": [
        {
          "speaker": "司令官",
          "text": "你们苏醒的时间最早是五十年后——也可能更长。你们要适应未来，同时要保持我们这个时代军人的灵魂。"
        },
        {
          "text": "章北海没有问为什么选他。他知道。"
        },
        {
          "speaker": "章北海",
          "text": "首长，我只有一个请求：让我们到舰队的最基层去做普通士兵。"
        },
        {
          "speaker": "司令官",
          "text": "你们都将被任命为执行舰长——集中型指挥系统的战舰需要你们这样的人。"
        }
      ],
      "choices": [
        {
          "text": "接受任命",
          "next": "ch5_aftermath_003"
        }
      ]
    },
    "ch5_aftermath_003": {
      "scene": {
        "id": "airport",
        "name": "机场",
        "type": "major",
        "description": "冬日的天空压得很低，太阳在薄云后发出无力的白光。一架运输机停在跑道上，舷梯已经放下。",
        "arrival": "送行那天——"
      },
      "progress": 29,
      "segments": [
        {
          "text": "常伟思把一封信交到章北海手里。"
        },
        {
          "speaker": "常伟思",
          "text": "这是给我未来继任者的信。我在信中介绍了你们的情况。你们苏醒后可能面临更加严峻的工作环境——首先要适应未来，同时要保持我们这个时代军人的灵魂。"
        },
        {
          "speaker": "章北海",
          "text": "首长——我第一次为无神论者感到一些遗憾。否则我们就可以怀着希望在某个时间某个地方最后相聚。"
        }
      ],
      "choices": [
        {
          "text": "敬礼——转身登机",
          "next": "ch5_aftermath_004"
        }
      ]
    },
    "ch5_aftermath_004": {
      "scene": "机场",
      "progress": 31,
      "segments": [
        {
          "text": "常伟思看着章北海的背影消失在舱门中。"
        },
        {
          "text": "这个坚定的战士走了。可能不会再有第二个他这样的人。"
        },
        {
          "text": "他是对的还是错的？常伟思不知道。也许永远都不会知道了。"
        }
      ],
      "changes": {
        "addFlag": "zhang_frozen",
        "unlockAchievement": "augment_future"
      },
      "next": "ch5_hines_001"
    },
    "ch5_hines_001": {
      "chapterTitle": "",
      "scene": {
        "id": "hines_lab",
        "name": "脑科学实验室",
        "type": "major",
        "description": "白雾弥漫。柔光从上方投射下来，像月光穿过云层。空气中很干燥。远处隐约能看见巨大的球状结构，是一个大脑的全息显示。",
        "arrival": "危机纪年第20年。三体舰队距太阳系4.15光年。"
      },
      "progress": 34,
      "ambient": "static",
      "segments": [
        {
          "speaker": "系统",
          "text": "雷迪亚兹和你被同时从冬眠中唤醒了。八年过去，你们要等的东西终于出现了。"
        },
        {
          "text": "你叫比尔·希恩斯。你拖着冬眠后僵硬的脚步，走进这座形似体育馆的建筑。白雾中站着一个娇小的人影，是山杉惠子。"
        }
      ],
      "choices": [
        {
          "text": "走近她",
          "next": "ch5_hines_002"
        }
      ]
    },
    "ch5_hines_002": {
      "scene": "脑科学实验室",
      "progress": 36,
      "segments": [
        {
          "speaker": "你",
          "text": "不是说好两年后你也冬眠吗？为什么一直等到现在？"
        },
        {
          "speaker": "山杉惠子",
          "text": "本来想做一些准备，但事情太多就一直做下来了。计算机性能不够。量子、生物、非冯结构——全都失败了。最后还是传统结构。"
        },
        {
          "speaker": "山杉惠子",
          "text": "但这真的是尽头了。摩尔定律这颗柠檬里，最后一滴汁。"
        }
      ],
      "choices": [
        {
          "text": "看解析摄像机的演示",
          "next": "ch5_hines_003"
        }
      ]
    },
    "ch5_hines_003": {
      "scene": "脑科学实验室",
      "progress": 38,
      "segments": [
        {
          "text": "山杉惠子按动鼠标。白雾变了，粗化，放大。每一颗微粒都变成了闪亮的星星。"
        },
        {
          "text": "一千亿颗星星，每一个就是一个神经元。"
        },
        {
          "speaker": "山杉惠子",
          "text": "这是一个大脑结构的全视网。解析摄像机拍摄的，三百万个截面同时动态扫描。"
        },
        {
          "text": "星海扰动起来，有些地方像河流，有些像旋涡，有些像横扫一切的潮汐。在浩渺的混沌中，不时出现自组织的美图。"
        },
        {
          "speaker": "你",
          "text": "这是谁的大脑？"
        },
        {
          "speaker": "山杉惠子",
          "text": "（微笑）我的。出现这幅思维图景的时候，我正在想你。"
        }
      ],
      "choices": [
        {
          "text": "观看测试",
          "next": "ch5_hines_004"
        }
      ]
    },
    "ch5_hines_004": {
      "scene": "脑科学实验室",
      "progress": 40,
      "segments": [
        {
          "text": "屏幕上逐条显示命题。受试者根据判断按动左右手的按钮：真，或伪。"
        },
        {
          "text": "煤是黑色的。真。1+1=2。真。男人的个子一般比女人矮。伪。"
        },
        {
          "text": "然后命题5号：水是剧毒的。"
        }
      ],
      "choices": [
        {
          "text": "观察结果",
          "next": "ch5_hines_005"
        }
      ]
    },
    "ch5_hines_005": {
      "scene": "脑科学实验室",
      "progress": 42,
      "segments": [
        {
          "text": "受试者按下了「伪」。但在那之后的两天里他滴水不进，拒绝喝水，认为水有毒。"
        },
        {
          "text": "你亲自走进解析拍摄室。你在同样的命题下按了「伪」。你走出来，拿起水杯，喝了一小口。"
        },
        {
          "text": "然后你吐了。你开始相信水是剧毒的。"
        }
      ],
      "choices": [
        {
          "text": "——",
          "next": "ch5_hines_006"
        }
      ]
    },
    "ch5_hines_006": {
      "scene": "脑科学实验室",
      "progress": 44,
      "segments": [
        {
          "speaker": "你",
          "text": "生命在水中产生并且离不开水。我现在的身体百分之七十是水。但，我相信它是剧毒的。"
        },
        {
          "text": "山杉惠子含泪看着你。你和她都明白了：解析摄像机不仅能读取思维，它还能改写判断。"
        }
      ],
      "choices": [
        {
          "text": "——",
          "next": "ch5_hines_007"
        }
      ]
    },
    "ch5_hines_007": {
      "chapterTitle": "",
      "scene": {
        "id": "un_hall",
        "name": "联合国·行星防御理事会",
        "type": "major",
        "description": "大圆桌。各常任理事国代表的脸上是高度戒备的表情。今天的议题只有一个：思想钢印。",
        "arrival": "PDC听证会。"
      },
      "progress": 46,
      "segments": [
        {
          "speaker": "你",
          "text": "思想钢印可以固化一个信念。比如「人类必胜」。"
        },
        {
          "text": "会场骚动起来。"
        },
        {
          "speaker": "美国代表",
          "text": "这是打开了一扇通向黑暗的大门。"
        }
      ],
