    "ch4_pdc_003": {
      "scene": {
        "id": "pdc",
        "name": "PDC会议",
        "type": "major"
      },
      "progress": 30,
      "segments": [
        {
          "speaker": "罗辑",
          "text": "这是一次实验。用于证实我自己的战略设想。真正的实施要在末日之战到来时。"
        },
        {
          "speaker": "PDC轮值主席",
          "text": "那在这一百年或更长的时间里——你打算做什么？"
        },
        {
          "speaker": "罗辑",
          "text": "冬眠。当观测到咒语在187J3X1星系上发生作用时叫醒我。"
        }
      ],
      "choices": [
        {
          "text": "冬眠——等待咒语的结果",
          "next": "end_wait_closure_01",
          "changes": {
            "val": 10,
            "addFlag": "chose_hibernate_wait",
            "importantFlag": {
              "flag": "chose_hibernate_wait",
              "label": "选择冬眠等待"
            }
          }
        },
        {
          "text": "拒绝发射咒语——我不干了",
          "next": "ch4_pdc_003_refuse",
          "changes": {
            "val": -20,
            "addFlag": "refused_spell",
            "importantFlag": {
              "flag": "refused_spell",
              "label": "拒绝发射咒语"
            }
          }
        },
        {
          "text": "“继续陈述。”",
          "next": "ch4_pdc_004"
        }
      ]
    },
