  "nodes": {
    "hy_ye_001": {
      "chapterTitle": "红岸",
      "scene": {
        "id": "struggle_hall",
        "name": "清华大学·批斗会场",
        "type": "major",
        "description": "操场。临时搭起的主席台上站着一排人。他们胸前挂着木牌，上面写着各种标语。台下人头攒动——口号声像海浪一样一波接一波。空气中弥漫着灰尘和汗水的味道。",
        "arrival": "1967年。你站在人群中。"
      },
      "progress": 1,
      "segments": [
        {
          "text": "你叫叶文洁。你二十四岁。你站在清华大学的操场上——看着你的父亲。"
        },
        {
          "text": "叶哲泰站在主席台上。他胸前挂着一块沉重的木牌——「反动学术权威」。但他没有低头。他用瘦弱的脖颈支撑着那块木牌，像支撑着一面旗帜。"
        }
      ],
      "choices": [
        {
          "text": "——",
          "next": "hy_ye_002"
        }
      ]
    },
    "hy_ye_002": {
      "scene": "清华大学·批斗会场",
      "progress": 3,
      "segments": [
        {
          "speaker": "（台前的人用扩音器喊着）",
          "text": "叶哲泰——你向学生散布了多少反动言论！"
        },
        {
          "speaker": "叶哲泰",
          "text": "我讲的是物理学。"
        },
        {
          "text": "他的声音不大，但很稳。就像他上课时那样。"
        },
        {
          "speaker": "喊话的人",
          "text": "物理学？所谓的自然规律——不过是帝国主义和修正主义用来麻痹人民的工具！"
        }
      ],
      "choices": [
        {
          "text": "——",
          "next": "hy_ye_003"
        }
      ]
    },
    "hy_ye_003": {
      "scene": "清华大学·批斗会场",
      "progress": 5,
      "segments": [
        {
          "text": "然后你的母亲——绍琳——走上了台。你从没想过会在这种情况下看到她站在父亲旁边。"
        },
        {
          "speaker": "绍琳",
          "text": "我揭发——叶哲泰在量子力学的教学中，大量散布哥本哈根解释的反动言论。这是最猖狂的主观唯心主义！"
        },
        {
          "text": "台下的口号声更响了。你的耳朵在嗡嗡作响。你的父亲转过头——看了你母亲一眼。那一眼里没有愤怒。只有一种你读不懂的东西。"
        }
      ],
      "choices": [
        {
          "text": "闭上眼",
          "next": "hy_ye_003_cb_a"
        },
        {
          "text": "强迫自己看下去",
          "next": "hy_ye_003_cb_b"
        }
      ]
    },
    "hy_ye_004": {
      "scene": "清华大学·批斗会场",
      "progress": 7,
      "segments": [
        {
          "text": "你选择了——"
        },
        {
          "text": "太阳很刺眼。你听到了一声闷响——睁开眼睛的时候，你父亲已经倒在了地上。他的脑门上有一道清晰的伤痕——黄铜扣子的形状。血从那里涌了出来。"
        },
        {
          "text": "没有人去扶他。台上的口号还在继续。"
        }
      ],
      "changes": {
        "addFlags": [
          "witnessed_father_death"
        ],
        "unlockAchievements": [
          "witness_struggle"
        ]
      },
      "choices": [
        {
          "text": "冲上去",
          "next": "hy_ye_005a",
          "changes": {
            "set": {
              "ye_psyche": "warm"
            }
          }
        },
        {
          "text": "转身离开人群",
          "next": "hy_ye_005b",
          "changes": {
            "set": {
              "ye_psyche": "cold"
            }
          }
        }
      ]
    },
    "hy_ye_005a": {
      "scene": "清华大学·批斗会场",
      "progress": 8,
      "segments": [
        {
          "text": "你拨开人群冲了上去。有人拉住了你的手臂——你没有挣脱开。你被拖回了人群中。你看到父亲的身体被几个人拖走了——在地上画出一道红色的痕迹。"
        }
      ],
      "next": "hy_ye_006"
    },
    "hy_ye_005b": {
      "scene": "清华大学·批斗会场",
      "progress": 8,
      "segments": [
        {
          "text": "你转身走了。身后是震耳欲聋的口号声——你没有回头。你走出校门的时候，阳光很刺眼。你的手在发抖。"
        }
      ],
      "next": "hy_ye_006"
    },
    "hy_ye_006": {
      "scene": {
        "id": "forestry",
        "name": "大兴安岭·伐木场",
        "type": "major",
        "description": "雪。白色的雪覆盖了一切。树木被砍伐后的树桩像墓碑一样立在雪中。远处传来油锯的声音——尖锐，刺耳。空气冷得像刀片。",
        "arrival": "几个月后。你被送到大兴安岭。"
      },
      "progress": 10,
      "segments": [
        {
          "text": "这里很冷。冷到你有时候觉得——如果就这样被冻死在这里——也许不是坏事。"
        },
        {
          "text": "伐木场的工人们不太和你说话。他们知道你是从北京来的——知道你的父亲是「反动学术权威」。没有人愿意靠近你。"
        },
        {
          "text": "直到有一天——一辆军用吉普车出现在了伐木场的门口。"
        }
      ],
      "choices": [
        {
          "text": "——",
          "next": "hy_ye_007"
        }
      ]
    },
    "hy_ye_007": {
      "scene": "大兴安岭·伐木场",
      "progress": 12,
      "segments": [
        {
          "speaker": "（车上下来一个穿军装的人）",
          "text": "叶文洁——收拾东西，跟我走。"
        },
        {
          "speaker": "你",
          "text": "去哪儿？"
        },
        {
          "speaker": "军人",
          "text": "一个需要你的地方。"
        }
      ],
      "choices": [
        {
          "text": "跟他走",
          "next": "hy_ye_008"
        },
        {
          "text": "站在原地不动",
          "next": "hy_ye_008"
        }
      ]
    },
    "hy_ye_008": {
      "scene": {
        "id": "red_coast",
        "name": "红岸基地",
        "type": "major",
        "description": "建在山体内部的基地。走廊很长，天花板很低。头顶的日光灯发出惨白色的光，照在墙上的标语上——「深挖洞，广积粮，不称霸」。远处传来机器运转的嗡鸣。",
        "arrival": "你被带进了一座山。"
      },
      "changes": {
        "unlockAchievements": [
          "enter_redcoast"
        ]
      },
      "progress": 14,
      "segments": [
        {
          "text": "你通过了三道岗哨——每一道都要检查证件和通行令。这里的气氛和大兴安岭完全不同——没有雪，没有树，没有风。只有水泥和钢铁。"
        },
        {
          "speaker": "军人",
          "text": "从今天起——你在这里工作。内容不得对任何人提起。你的对外身份是国防科工委下属科研单位的技术员。"
        }
      ],
      "choices": [
        {
          "text": "接受任命",
          "next": "hy_ye_009"
        }
      ]
    },
    "hy_ye_009": {
      "scene": "红岸基地",
      "progress": 16,
      "segments": [
        {
          "text": "你被分配到一个叫「红岸工程」的项目组。没有人告诉你这个项目的全部内容——你只负责一个模块：信号处理。"
        },
        {
          "text": "你的直属上级叫雷志成——一个四十岁左右的技术军官，说话不多，眼神总是带着审视。另一个是杨卫宁——总工程师，戴着厚厚的眼镜，说话慢条斯理。"
        },
        {
          "speaker": "雷志成",
          "text": "你的工作是分析接收到的信号。记录任何异常。"
        }
      ],
      "choices": [
        {
          "text": "「什么样的异常？」",
          "next": "hy_ye_009_cb_a",
          "changes": {
            "val": 3
          }
        },
        {
          "text": "沉默地点头",
          "next": "hy_ye_009_cb_b",
          "changes": {
            "val": -2
          }
        }
      ]
    },
    "hy_ye_010": {
      "scene": "红岸基地·接收室",
      "progress": 18,
      "segments": [
        {
          "text": "你很快发现——红岸基地的真实目的不是「国防科研」。它是一座射电望远镜——一座巨大、隐蔽、向宇宙深处倾听的耳朵。"
        },
        {
          "text": "而在一个深夜——你独自值班的时候——你发现了一个秘密。那台设备不仅能够接收信号。它也能发射。大功率发射。"
        },
        {
          "text": "你面前的控制台上——有一个红色的按钮。旁边写着——「未获批准不得操作」."
        }
      ],
      "changes": {
        "addFlags": [
          "discovered_transmit"
        ]
      },
      "choices": [
        {
          "text": "——",
          "next": "hy_ye_011"
        }
      ]
    },
    "hy_ye_011": {
      "scene": "红岸基地·接收室",
      "progress": 20,
      "segments": [
        {
          "text": "你没有按那个按钮。至少——不是那天晚上。"
        },
        {
          "text": "你开始利用职务之便研究那台设备的完整图纸。你在雷志成的办公室里找到了关于「太阳放大器」的理论文件。"
        },
        {
          "text": "太阳可以作为一个超级天线——把信号放大几亿倍。如果你把信号对准太阳——它会以十倍、百倍、千倍的强度被广播到整个宇宙。"
        },
        {
          "text": "你用了半年时间确认了这件事的可行性。然后你在一个雷志成和杨卫宁都不在的深夜——坐到了控制台前。"
        }
      ],
      "choices": [
        {
          "text": "发送信号",
          "next": "hy_ye_012",
          "changes": {
            "val": 10,
            "set": {
              "ye_psyche": "warm"
            }
          }
        },
        {
          "text": "犹豫——再想想",
          "next": "hy_ye_011_hesitate",
          "changes": {
            "val": -5,
            "set": {
              "ye_psyche": "cold"
            }
          }
        }
      ]
    },
    "hy_ye_011_hesitate": {
      "progress": 21,
      "segments": [
        {
          "text": "你的手悬在那个红色按钮上方。冰冷的水泥墙面、父亲额头的伤痕、绍琳歇斯底里的口号声在你脑海中交织。"
        },
        {
          "text": "理智告诉你这可能是一个无法挽回的错误。但内心的死寂和对这个世界的绝望——最终压倒了最后一丝犹豫。你的手指无声地沉了下去。"
        }
      ],
      "next": "hy_ye_012"
    },
    "hy_ye_012": {
      "scene": "红岸基地·接收室",
      "progress": 22,
      "effect": "flash",
      "segments": [
        {
          "text": "你按下了发射键。"
        },
        {
          "text": "控制台上的仪表跳动了一下。天线开始转动——对准了太阳。你听到电力系统发出低沉的嗡鸣——那是能量在被注入天线的声音。"
        },
        {
          "text": "一束电波——携带着人类文明的问候——射向太阳。它将在穿过日冕层时被放大数亿倍——然后向宇宙深处扩散。"
        },
        {
          "text": "你坐回椅子上。你突然发现——自己在哭。你不知道为什么。"
        }
      ],
      "next": "hy_batch_end"
    },
    "hy_batch_end": {
      "progress": 25,
      "segments": [
        {
          "text": "叶文洁按下了那个按钮。她向宇宙发出了人类文明的第一个信号。"
        },
        {
          "text": "但她不知道——那个信号会被三体世界收到。她不知道——三体监听员会在深夜回复三个字：「不要回答。」她更不知道——她会在八年后回复那条信息，暴露地球的坐标。"
        },
        {
          "text": "她只知道——在那个深夜，她做了一件没有任何人类做过的事。"
        },
        {
          "text": "她朝黑暗中的森林——开了一枪。"
        }
      ],
      "next": "hy_ye_013"
    },
    "hy_ye_003_cb_a": {
      "progress": 5,
      "segments": [
        {
          "text": "你闭上了眼睛。但声音还在——口号声、闷响、然后是寂静。"
        }
      ],
      "next": "hy_ye_004"
    },
    "hy_ye_003_cb_b": {
      "progress": 5,
      "segments": [
        {
          "text": "你睁着眼看完了全过程。阳光很刺眼。"
        }
      ],
      "next": "hy_ye_004"
    },
    "hy_ye_009_cb_a": {
      "progress": 16,
      "segments": [
        {
          "text": "雷志成看了你一眼。他似乎在判断——你是真的好奇，还是在试探。"
        }
      ],
      "next": "hy_ye_010"
    },
    "hy_ye_009_cb_b": {
      "progress": 16,
      "segments": [
        {
          "text": "你点了点头。雷志成转身离开了。门关上后，房间里只剩下仪器的嗡鸣。"
        }
      ],
      "next": "hy_ye_010"
    }
  }
}