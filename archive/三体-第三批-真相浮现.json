      ],
      "next": "wei_008"
    },
    "wei_008": {
      "segments": [
        {
          "text": "史强推门进来，脸色不太好。"
        },
        {
          "speaker": "史强",
          "text": "找到申玉菲了。或者说——她找到我们了。她传来一个口信：想见你。单独。"
        },
        {
          "text": "他看着你。"
        },
        {
          "speaker": "史强",
          "text": "她说她知道你在查什么。她说——如果你想见真正的三体文明——今晚就来。\""
        }
      ],
      "choices": [
        {
          "text": "\"我去。\"",
          "next": "wei_008_eto_001_cb0",
          "changes": {
            "val": 3
          }
        },
        {
          "text": "\"这可能是个陷阱。\"",
          "next": "wei_008_eto_001_cb1"
