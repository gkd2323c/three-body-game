  "nodes": {
    "chang_001": {
      "chapterTitle": "第三幕：真相浮现",
      "title": "会面",
      "scene": {
        "id": "military_office",
        "name": "作战中心",
        "description": "一间不起眼的办公楼里，会议室被改造成了临时作战中心。墙上挂着星图、地球全景图，还有几块写满公式的白板。"
      },
      "progress": 55,
      "segments": [
        {
          "text": "史强带你走进那间会议室的时候，里面已经坐了七八个人。常伟思坐在长桌一端，旁边是几个穿军装和不穿军装的人。所有人的目光都落在你身上。"
        },
        {
          "text": "\"坐，汪教授。\"常伟思指了指对面的椅子。\"听说你昨晚没闲着。\""
        }
      ],
      "choices": [
        {
          "text": "\"我登录了三体游戏。\"",
          "next": "chang_001_chang_002_cb0",
          "changes": {
            "val": 2
          }
        },
        {
          "text": "\"叶文洁告诉我的事——都是真的。\"",
          "next": "chang_001_chang_002_cb1",
          "changes": {
            "val": 1
          }
        },
        {
          "text": "\"事情比我们想象的严重得多。\"",
          "next": "chang_001_chang_002_cb2"
        }
      ],
      "next": "chang_002"
    },
    "chang_002": {
      "segments": [
        {
          "text": "你用尽量简短的语言说了你经历的一切。叶文洁的故事、红岸基地、三体游戏中的文明轮回。你注意到当你提到「三颗太阳」的时候，白板前的一个戴眼镜的中年人飞快地在本子上记了什么。"
        },
        {
          "text": "常伟思听完了，沉默了大概十秒钟。然后他转向那个中年人。"
        },
        {
          "speaker": "常伟思",
          "text": "老张，你那边呢？"
        }
      ],
      "choices": [
        {
          "text": "等待他继续说",
          "next": "chang_003"
        }
      ],
      "next": "chang_003"
    },
    "chang_003": {
      "segments": [
        {
          "text": "那个叫老张的人推了推眼镜。"
        },
        {
          "speaker": "老张",
          "text": "我们追踪了一个叫申玉菲的人。科学边界核心成员。三天前她向几个同行发送了一封邮件，内容很简短——'14日凌晨，注意观察宇宙背景辐射。'"
        },
        {
          "text": "你的后背一紧。"
        },
        {
          "speaker": "老张",
          "text": "我们一开始以为是恶作剧。但——「他看了看手表，\"现在距离14日凌晨还有不到七个小时。\""
        }
      ],
      "choices": [
        {
          "text": "\"我知道申玉菲。她给过我一个网址。\"",
          "next": "chang_003_chang_004_cb0"
        },
        {
          "text": "\"宇宙背景辐射——她能预测这个？\"",
          "next": "chang_003_chang_004_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "chang_004"
    },
    "chang_004": {
      "segments": [
        {
          "speaker": "常伟思",
          "text": "所以我们需要你今晚去一趟观测站。如果是巧合，最好。如果不是——"
        },
        {
          "text": "他没有说完。但在场所有人都知道他想说什么。"
        },
        {
          "speaker": "史强",
          "text": "我送你去。车在外面。"
        }
      ],
      "choices": [
        {
          "text": "\"好，我去。\"",
          "next": "chang_004_chang_005_cb0",
          "changes": {
            "val": 3
          }
        },
        {
          "text": "\"我需要联系叶文洁。\"",
          "next": "chang_004_chang_005_cb1"
        },
        {
          "text": "\"如果真被她预测中了——那意味着什么？\"",
          "next": "chang_004_chang_005_cb2"
        }
      ],
      "next": "chang_005"
    },
    "chang_005": {
      "segments": [
        {
          "speaker": "常伟思",
          "text": "目前不要联系叶文洁。她已经被我们的人保护起来了——是以安全的名义，不是以嫌疑人的名义。等今晚过了再说。"
        },
        {
          "text": "他站起来，走到你面前伸出手。"
        },
        {
          "speaker": "史强",
          "text": "汪教授，不管今晚看到什么——保持冷静。你是科学家。科学家不相信自己眼睛的时候，相信数据。"
        }
      ],
      "choices": [
        {
          "text": "握他的手",
          "next": "chang_005_chang_006_cb0",
          "changes": {
            "val": 2
          }
        },
        {
          "text": "\"我尽量。\"",
          "next": "chang_005_chang_006_cb1"
        }
      ],
      "next": "chang_006"
    },
    "chang_006": {
      "title": "观测站",
      "scene": {
        "id": "observatory",
        "name": "射电天文观测站",
        "description": "郊外的山头上，几座白色抛物面天线在月光下反射着冷光。控制室里屏幕幽蓝，设备发出平稳的白噪音。"
      },
      "segments": [
        {
          "text": "史强的车在凌晨一点前到达了观测站。接应你的是一位叫沙瑞山的研究员——杨冬生前的同事。他显然已经接到了通知，没有多问，直接把你带进了控制室。"
        },
        {
          "speaker": "沙瑞山",
          "text": "设备已经对准了目标空域。如果有什么异常的辐射波动，我们会在第一时间看到。"
        }
      ],
      "choices": [
        {
          "text": "\"你觉得会看到什么？\"",
          "next": "chang_006_flicker_001_cb0"
        },
        {
          "text": "你盯着屏幕上的数据曲线",
          "next": "chang_006_flicker_001_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "flicker_001"
    },
    "flicker_001": {
      "title": "宇宙闪烁",
      "chapterTitle": "宇宙闪烁",
      "scene": "控制室",
      "progress": 60,
      "ambient": "static",
      "segments": [
        {
          "speaker": "沙瑞山",
          "text": "宇宙背景辐射——你应该知道，这是大爆炸的余晖。它在所有方向上是均匀的，温度波动不超过十万分之一。这是宇宙学最坚实的观测基础之一。"
        },
        {
          "text": "他指着屏幕上的那条几乎水平的线。"
        },
        {
          "speaker": "沙瑞山",
          "text": "你看，这是实时数据。完全正常。"
        }
      ],
      "choices": [
        {
          "text": "盯着那条线看",
          "next": "flicker_001_flicker_002_cb0"
        },
        {
          "text": "你有一种预感——它马上就要变了",
          "next": "flicker_001_flicker_002_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "flicker_002"
    },
    "flicker_002": {
      "segments": [
        {
          "text": "凌晨一点十七分。那条线动了。"
        },
        {
          "text": "不是仪器误差的那种细微抖动——是明显的、有规律的波动。像一个信号。"
        },
        {
          "speaker": "沙瑞山",
          "text": "不可能……"
        },
        {
          "text": "他飞快地敲击键盘，调出多个校准参数。所有自检程序都显示设备正常。"
        },
        {
          "speaker": "沙瑞山",
          "text": "这不可能。"
        }
      ],
      "effect": "breath",
      "choices": [
        {
          "text": "\"是什么导致的？\"",
          "next": "flicker_002_flicker_003_cb0"
        },
        {
          "text": "你盯着那条波动的曲线，说不出话",
          "next": "flicker_002_flicker_003_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "flicker_003"
    },
    "flicker_003": {
      "segments": [
        {
          "speaker": "沙瑞山",
          "text": "不知道……这完全违背了宇宙学的基本原理。宇宙背景辐射是各向同性的，是均匀的——它在任何一个方向上都应该是一样的。除非——"
        },
        {
          "text": "他停住了。他转过头来看着你，脸色苍白。"
        },
        {
          "speaker": "沙瑞山",
          "text": "除非有人在拨弄宇宙。"
        }
      ],
      "choices": [
        {
          "text": "\"拨弄宇宙？\"",
          "next": "flicker_003_flicker_004_cb0"
        },
        {
          "text": "你感到一阵深入骨髓的寒意",
          "next": "flicker_003_flicker_004_cb1",
          "changes": {
            "val": -5
          }
        }
      ],
      "next": "flicker_004"
    },
    "flicker_004": {
      "segments": [
        {
          "text": "曲线继续波动。然后——你看到了一排数字。在波动的曲线上方，时间轴上，数字正在以肉眼可见的速度变化。"
        },
        {
          "text": "1174:20:35。"
        },
        {
          "text": "它像钟表一样在走。倒计时。"
        },
        {
          "text": "你盯着那串数字，感觉整个世界的重力都在向你压过来。"
        }
      ],
      "ambient": "none",
      "choices": [
        {
          "text": "\"这是给我的。\"",
          "next": "flicker_004_flicker_005_cb0",
          "changes": {
            "val": -5
          }
        },
        {
          "text": "\"记录下所有数据。\"",
          "next": "flicker_004_flicker_005_cb1",
          "changes": {
            "val": 2
          }
        }
      ],
      "next": "flicker_005"
    },
    "flicker_005": {
      "segments": [
        {
          "text": "倒计时走到1174:20:35，停住了。数字不再变化。"
        },
        {
          "text": "沙瑞山瘫倒在椅子上，额头上全是汗。\"这是——这是某种形式的干涉。有东西——我不知道是什么——在屏蔽和修改我们接收到的宇宙背景辐射信号。\""
        },
        {
          "text": "\"能做到这一点的技术——远远超出了人类的认知范围。\""
        },
        {
          "text": "你拿出手机，拨了史强的号码。电话接通了，你没有等他开口。"
        },
        {
          "speaker": "你",
          "text": "她说的没错。整个宇宙——刚才在闪烁。"
        }
      ],
      "achievements": {
        "unlockAchievement": "cosmic_flicker"
      },
      "choices": [
        {
          "text": "继续",
          "next": "flicker_006",
          "changes": {
            "addFlag": "saw_cosmic_flicker"
          }
        }
      ],
      "next": "flicker_006"
    },
    "flicker_006": {
      "title": "返回",
      "scene": {
        "id": "car_return_night",
        "name": "夜路",
        "description": "回程的路上，路灯一盏一盏地掠过车窗。"
      },
      "segments": [
        {
          "text": "史强来接你的时候什么都没问。你坐进车里，他看了你一眼，然后发动了车子。"
        },
        {
          "text": "沉默持续了五分钟。然后史强开口了。"
        },
        {
          "speaker": "史强",
          "text": "我以前办过一个案子。一个人说他看见了鬼。我不信鬼。但我信那个人确实看见了什么。你明白我的意思吗？"
        },
        {
          "text": "你没有回答。但你明白。"
        }
      ],
      "choices": [
        {
          "text": "\"接下来怎么办？\"",
          "next": "flicker_006_flicker_007_cb0"
        },
        {
          "text": "你闭上眼睛——需要时间消化这一切",
          "next": "flicker_006_flicker_007_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "flicker_007"
    },
    "flicker_007": {
      "segments": [
        {
          "speaker": "史强",
          "text": "常将军说了，天亮之后有一个新人物要介绍给你。申玉菲的丈夫——一个搞数学的，叫魏成。这家伙据说一个人在屋子里算了几年，算出了点东西。"
        },
        {
          "speaker": "史强",
          "text": "而且——申玉菲今天早上失踪了。"
        }
      ],
      "choices": [
        {
          "text": "\"魏成？他算出了什么？\"",
          "next": "flicker_007_wei_001_cb0",
          "changes": {
            "val": 2
          }
        },
        {
          "text": "\"申玉菲失踪了？什么时候？\"",
          "next": "flicker_007_wei_001_cb1"
        }
      ],
      "next": "wei_001"
    },
    "wei_001": {
      "chapterTitle": "三体问题",
      "title": "魏成",
      "scene": {
        "id": "wei_cheng_home",
        "name": "魏成的住处",
        "description": "不像一个家，更像一个仓库。到处都是打印出来的数学公式，墙上贴满了奇形怪状的图形——有些像分形，有些像混沌系统的时间序列图。空气中有股烟味和方便面的味道。"
      },
      "progress": 65,
      "segments": [
        {
          "text": "你见到魏成的时候，他正蹲在地上，对着一张铺满整个地板的巨大图表发呆。图表上有密密麻麻的手写数字和曲线，像某种天书。"
        },
        {
          "text": "他抬起头来看了看你，又低下头去看他的图表，好像你是另一个无关紧要的访客。"
        },
        {
          "speaker": "史强",
          "text": "老魏，这位是汪教授。你把你的东西给他看看。"
        }
      ],
      "choices": [
        {
          "text": "蹲下来看他地上的图表",
          "next": "wei_001_wei_002_cb0",
          "changes": {
            "val": 2
          }
        },
        {
          "text": "等他先开口",
          "next": "wei_001_wei_002_cb1"
        }
      ],
      "next": "wei_002"
    },
    "wei_002": {
      "segments": [
        {
          "speaker": "魏成",
          "text": "三体问题。三个质量相近的天体在引力作用下的运动。几百年来没人找到解析解。我也没找到。"
        },
        {
          "text": "他站起来，从桌上拿起一沓手稿，递给你。上面全是数学符号。"
        },
        {
          "speaker": "魏成",
          "text": "但我找到了另一种东西——数值解的规律。当初始条件满足某些特征时，三体运动会呈现周期性的模式。我把这些模式归类了。一共有一千一百九十种。"
        }
      ],
      "choices": [
        {
          "text": "\"这些模式——能预测太阳的运行？\"",
          "next": "wei_002_wei_003_cb0"
        },
        {
          "text": "你翻阅那些手稿，被它们的精确和庞大震撼了",
          "next": "wei_002_wei_003_cb1",
          "changes": {
            "val": 2
          }
        }
      ],
      "next": "wei_003"
    },
    "wei_003": {
      "segments": [
        {
          "speaker": "魏成",
          "text": "不能。模式只能告诉你：在某个时间窗口内，系统会呈现什么样的宏观行为。精确预测——那需要计算量。超出了地球上所有计算机的总和。"
        },
        {
          "text": "他停了停。"
        },
        {
          "speaker": "魏成",
          "text": "但我妻子——申玉菲——她对我的研究非常感兴趣。她每个月都会来看我的进展。一开始我以为她关心我的工作，后来我发现——她把我的数据发给了别人。"
        }
      ],
      "choices": [
        {
          "text": "\"她发给了谁？\"",
          "next": "wei_003_wei_004_cb0"
        },
        {
          "text": "你心里已经有了答案——ETO",
          "next": "wei_003_wei_004_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "wei_004"
    },
    "wei_004": {
      "segments": [
        {
          "speaker": "魏成",
          "text": "我不知道。她从来不告诉我。但有一次——我在她书房里看到一个文件，标题是'三体游戏技术文档'。"
        },
        {
          "text": "他抬头看着你，目光里有一种说不清的东西——是好奇，还是恐惧，你分辨不出。"
        },
        {
          "speaker": "魏成",
          "text": "那个文档里描述的三体星系——和我计算出来的结果——一模一样。"
        }
      ],
      "choices": [
        {
          "text": "你背后一凉",
          "next": "wei_004_wei_005_cb0",
          "changes": {
            "val": -3
          }
        },
        {
          "text": "\"这说明——三体游戏里的数据是真实的。\"",
          "next": "wei_004_wei_005_cb1"
        }
      ],
      "next": "wei_005"
    },
    "wei_005": {
      "segments": [
        {
          "speaker": "魏成",
          "text": "我不知道那游戏是什么。我不玩游戏。我只是做数学。"
        },
        {
          "text": "他重新蹲下来，手指在图表的某个区域画了一个圈。"
        },
        {
          "speaker": "魏成",
          "text": "但这里的计算结果——如果代入我的周期模型——那个三体星系正在进入一个长达数百万年的稳定期。三个太阳的轨道将趋于某种准周期状态。"
        },
        {
          "speaker": "魏成",
          "text": "对一个文明来说——这意味着恒纪元。一个很漫长很漫长的恒纪元。"
        }
      ],
      "choices": [
        {
          "text": "\"所以三体文明——他们正在迎来一段稳定期？\"",
          "next": "wei_005_wei_006_cb0"
        },
        {
          "text": "你意识到这个信息可能比叶文洁说的任何事都重要",
          "next": "wei_005_wei_006_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "wei_006"
    },
    "wei_006": {
      "segments": [
        {
          "speaker": "魏成",
          "text": "我不知道他们的事。我只知道——如果这个星系里真有文明——他们现在有了一个离开那个世界的窗口期。在这个窗口期结束之前——他们会不惜一切代价离开。"
        },
        {
          "text": "他看了看窗外，然后回过头来。"
        },
        {
          "speaker": "魏成",
          "text": "我妻子失踪了。我担心她——但我更担心她带走的东西。她把我的全部计算结果都拷贝走了。"
        }
      ],
      "choices": [
        {
          "text": "\"那些计算结果——能用来做什么？\"",
          "next": "wei_006_wei_007_cb0"
        },
        {
          "text": "你明白了——那些ETO的人需要这些数据",
          "next": "wei_006_wei_007_cb1",
          "changes": {
            "val": -2
          }
        }
      ],
      "next": "wei_007"
    },
    "wei_007": {
      "segments": [
        {
          "speaker": "魏成",
          "text": "如果三体运动的规律能被部分预测——那三体文明就能规划他们的星际旅行——知道什么时候出发最安全、什么时候到达最合适。"
        },
        {
          "text": "他顿了一下。"
        },
        {
          "speaker": "魏成",
          "text": "甚至——他们可以计算出——什么时候发起进攻最有利。"
        },
        {
          "text": "房间安静了几秒。远处传来史强打电话的声音，但话语听不清。"
        }
      ],
      "choices": [
        {
          "text": "继续",
          "next": "wei_008"
